<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/fullscreenContainer"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    android:visibility="gone">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Top Bar -->
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/fullscreenToolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/black"
            app:navigationIcon="@drawable/ic_chevron_down"
            app:navigationIconTint="@color/text_secondary"
            app:title=""
            app:titleTextColor="@color/white" />

        <!-- Content -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <!-- Video/Artwork Container -->
            <FrameLayout
                android:id="@+id/mediaContainer"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:background="@color/black">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <SurfaceView
                        android:id="@+id/videoSurface"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/fullscreenInitial"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="B"
                        android:textSize="160sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_secondary"
                        android:visibility="visible"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintLeft_toLeftOf="parent"
                        app:layout_constraintRight_toRightOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>

            </FrameLayout>

            <!-- Song Info -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="24dp">

                <TextView
                    android:id="@+id/fullscreenTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textColor="@color/white"
                    android:textSize="40sp"
                    android:textStyle="bold"
                    android:letterSpacing="-0.02" />

                <TextView
                    android:id="@+id/fullscreenArtist"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textColor="@color/red_main"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textAllCaps="true"
                    android:letterSpacing="0.1" />

            </LinearLayout>

        </LinearLayout>

        <!-- Controls -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="48dp"
            android:paddingBottom="32dp">

            <!-- Progress -->
            <FrameLayout
                android:id="@+id/fullscreenProgressContainer"
                android:layout_width="match_parent"
                android:layout_height="4dp"
                android:background="@color/gray_800"
                android:layout_marginBottom="8dp"
                android:clickable="true"
                android:focusable="true">

                <View
                    android:id="@+id/fullscreenProgress"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:background="@color/red_main" />

            </FrameLayout>

            <!-- Time -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2">

                <TextView
                    android:id="@+id/fullscreenCurrentTime"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="0:00"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:fontFamily="monospace" />

                <TextView
                    android:id="@+id/fullscreenTotalTime"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="0:00"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                    android:gravity="end" />

            </LinearLayout>

            <!-- Control Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="16dp">

                <ImageView
                    android:id="@+id/fullscreenShuffle"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_shuffle"
                    android:tint="@color/text_secondary"
                    android:layout_marginEnd="16dp"
                    android:clickable="true"
                    android:focusable="true" />

                <ImageView
                    android:id="@+id/fullscreenPrev"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_skip_back"
                    android:tint="@color/text_primary"
                    android:layout_marginEnd="16dp"
                    android:clickable="true"
                    android:focusable="true" />

                <ImageView
                    android:id="@+id/fullscreenPlayPause"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:src="@drawable/ic_play"
                    android:tint="@color/white"
                    android:background="@drawable/bg_fs_player_button"
                    android:padding="20dp"
                    android:layout_marginHorizontal="16dp"
                    android:clickable="true"
                    android:focusable="true" />

                <ImageView
                    android:id="@+id/fullscreenNext"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_skip_forward"
                    android:tint="@color/text_primary"
                    android:layout_marginStart="16dp"
                    android:clickable="true"
                    android:focusable="true" />

                <ImageView
                    android:id="@+id/fullscreenRepeat"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_repeat"
                    android:tint="@color/text_secondary"
                    android:layout_marginStart="16dp"
                    android:clickable="true"
                    android:focusable="true" />

                <ImageView
                    android:id="@+id/fullscreenMediaMode"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_monitor"
                    android:tint="@color/text_secondary"
                    android:layout_marginStart="16dp"
                    android:clickable="true"
                    android:focusable="true" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</FrameLayout>